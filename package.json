{
  "name": "@unmold/cli",
  "version": "0.1.0",
  "description": "Unmold CLI for registry automation",
  "homepage": "https://github.com/unmold-cloud/unmold-cli#readme",
  "bugs": {
    "url": "https://github.com/unmold-cloud/unmold-cli/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/unmold-cloud/unmold-cli.git"
  },
  "license": "UNLICENSED",
  "author": "",
  "main": "index.js",
  "scripts": {
    "unmold": "node ./bin/dev.js",
    "test:e2e": "npx dotenvx run -- node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON ./node_modules/mocha/bin/mocha --forbid-only \"tests/e2e/**/*.test.ts\"",
    "test:integration": "npx dotenvx run -- node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON ./node_modules/mocha/bin/mocha --forbid-only \"tests/integration/**/*.test.ts\"",
    "build": "tsc",
    "oclif": "oclif",
    "set-hooks": "npx simple-git-hooks",
    "pack:macos": "oclif pack macos",
    "pack:win": "oclif pack win",
    "preversion": "npm run build && npm run test:integration && npm run test:e2e",
    "prepublishOnly": "npm run build && npm run test:integration && npm run test:e2e"
  },
  "bin": {
    "unmold": "./bin/run.js"
  },
  "oclif": {
    "bin": "unmold",
    "commands": "./dist/commands",
    "dirname": "unmold",
    "topicSeparator": " ",
    "plugins": [
      "@oclif/plugin-help",
      "@oclif/plugin-not-found",
      "@oclif/plugin-version",
      "@oclif/plugin-update",
      "@oclif/plugin-warn-if-update-available"
    ],
    "macos": {
      "identifier": "com.unmold.cli"
    }
  },
  "dependencies": {
    "@inquirer/prompts": "^7.8.2",
    "@oclif/core": "^4.4.0",
    "@oclif/plugin-help": "^6.2.29",
    "@oclif/plugin-not-found": "^3.2.57",
    "@oclif/plugin-update": "^4.7.22",
    "@oclif/plugin-version": "^2.2.30",
    "@oclif/plugin-warn-if-update-available": "^3.1.42",
    "archiver": "^7.0.1",
    "ignore": "^7.0.0"
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "^1.51.0",
    "@oclif/test": "^4.1.13",
    "@types/archiver": "^6.0.3",
    "@types/chai": "^5.2.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "^18.19.113",
    "@types/node-fetch": "^2.6.12",
    "@types/uuid": "^10.0.0",
    "chai": "^5.2.0",
    "execa": "^9.6.1",
    "mocha": "^11.7.1",
    "nock": "^13.5.4",
    "node-fetch": "^3.3.2",
    "oclif": "^4.20.1",
    "prettier": "^3.6.2",
    "pretty-quick": "^4.2.2",
    "simple-git-hooks": "^2.13.0",
    "ts-jest": "^29.4.0",
    "ts-node": "^10.9.2",
    "uuid": "^11.1.0"
  },
  "simple-git-hooks": {
    "pre-commit": "npx pretty-quick --staged",
    "pre-push": "npm run test:integration"
  },
  "publishConfig": {
    "access": "public"
  }
}
